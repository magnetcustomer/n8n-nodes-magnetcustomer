{
  "name": "@magnetcustomer/n8n-nodes-magnetcustomer",
  "version": "2.1.1",
  "description": "n8n community node for Magnet Customer CRM — automate leads, deals, contacts, tasks and more",
  "keywords": [
    "n8n",
    "node",
    "no-code",
    "n8n-nodes-magnetcustomer",
    "n8n-community-nodes-magnetcustomer",
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://developers.magnetcustomer.com",
  "author": {
    "name": "Magnet Customer",
    "email": "dev@magnetcustomer.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/magnetcustomer/n8n-nodes-magnetcustomer.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "tslint -p tsconfig.json -c tslint.json && eslint nodes credentials package.json",
    "lintfix": "tslint --fix -p tsconfig.json -c tslint.json && eslint nodes credentials package.json --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "e2e:infra:start": "cd e2e && bash setup.sh",
    "e2e:infra:stop": "cd e2e && bash teardown.sh",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "credentials": [
      "dist/credentials/MagnetCustomerApi.credentials.js",
      "dist/credentials/MagnetCustomerOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/MagnetCustomer/MagnetCustomer.node.js",
      "dist/nodes/MagnetCustomer/MagnetCustomerTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/basic-auth": "^1.1.8",
    "@types/eslint": "^8.56.5",
    "@types/express": "^4.17.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.5",
    "@types/request-promise-native": "~1.0.15",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@vue/eslint-config-typescript": "^13.0.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-lodash": "^7.4.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-unicorn": "^51.0.1",
    "eslint-plugin-unused-imports": "^3.1.0",
    "eslint-plugin-vue": "^9.23.0",
    "gulp": "^4.0.2",
    "jest": "^30.3.0",
    "n8n-core": "^1.62.0",
    "n8n-workflow": "^1.62.0",
    "prettier": "^2.8.1",
    "ts-jest": "^29.4.9",
    "tslint": "^6.1.3",
    "typescript": "~5.6.0",
    "vue-eslint-parser": "^9.4.2"
  },
  "dependencies": {
    "basic-auth": "^2.0.1"
  }
}
